---
const { t } = Astro.props;
const { team } = t;
---

<section class="team" id="team" aria-labelledby="team-heading">
  <div class="container">
    <div class="section-label">{team.label}</div>
    <h2 class="team__heading" id="team-heading" data-animate="reveal">{team.heading}</h2>
    <ul class="team__list">
      {team.members.map((m) => (
        <li class="team__member" data-animate="fade">
          <a class="team__link" href={m.url} target="_blank" rel="noopener noreferrer">
            <img class="team__avatar" src={m.image} alt={m.alt} width="72" height="72" loading="lazy" decoding="async" />
            <span class="team__info">
              <span class="team__name">{m.name}</span>
              <span class="team__role">{m.role}</span>
              {m.desc && <span class="team__desc">{m.desc}</span>}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
