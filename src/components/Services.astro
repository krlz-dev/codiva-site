---
const { t } = Astro.props;
const { services } = t;
---

<section class="services" id="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="section-label">{services.label}</div>
    <h2 class="services__heading" id="services-heading" data-animate="reveal">{services.heading}</h2>
    <div class="services__grid">
      {services.cards.map((c) => (
        <article class="service-card" data-animate="card">
          <div class="service-card__number">{c.number}</div>
          <h3 class="service-card__title" set:html={c.title}></h3>
          <p class="service-card__desc">{c.desc}</p>
          <div class="service-card__line"></div>
        </article>
      ))}
    </div>
  </div>
</section>
