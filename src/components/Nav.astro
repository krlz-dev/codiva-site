---
const { t } = Astro.props;
const { nav } = t;
---

<nav class="nav" id="nav" aria-label={nav.ariaLabel}>
  <div class="nav__logo">
    <a href="#hero" aria-label={nav.logoAria}>codiva<span class="reg">®</span></a>
  </div>
  <div class="nav__links" id="navLinks" role="menubar">
    {nav.links.map((l) => (
      <a href={l.href} class="nav__link" role="menuitem">{l.label}</a>
    ))}
    <a href={nav.langSwitch.href} class="nav__lang" aria-label={nav.langSwitch.aria}>
      {nav.langSwitch.label}
    </a>
    <button
      class="nav__theme"
      id="themeToggle"
      type="button"
      aria-label={nav.themeToggle.toDark}
      title={nav.themeToggle.toDark}
      data-to-dark={nav.themeToggle.toDark}
      data-to-light={nav.themeToggle.toLight}
    >
      <svg class="nav__theme-icon nav__theme-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
      </svg>
      <svg class="nav__theme-icon nav__theme-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
      </svg>
    </button>
  </div>
  <button
    class="nav__burger"
    id="burger"
    aria-label={nav.burgerOpen}
    aria-expanded="false"
    data-open-label={nav.burgerOpen}
    data-close-label={nav.burgerClose}
  >
    <span></span>
    <span></span>
  </button>
</nav>
