---
const { t, variant = 'full' } = Astro.props;
const { projects, contact } = t;
const isTeaser = variant === 'teaser';
const items = isTeaser ? projects.items.slice(0, 3) : projects.items;
const heading = isTeaser ? (projects.teaserHeading || projects.heading) : projects.heading;
const Heading = isTeaser ? 'h2' : 'h1';
const wa = (msg) => `https://wa.me/${contact.whatsapp.number}?text=${encodeURIComponent(msg)}`;
---

<section class={`portfolio${isTeaser ? ' portfolio--teaser' : ''}`} id="projects" aria-labelledby="portfolio-heading">
  <div class="container">
    <div class="section-label">{projects.label}</div>
    <div class="portfolio__intro-row">
      <Heading class="portfolio__heading" id="portfolio-heading" data-animate="reveal">{heading}</Heading>
      {isTeaser && (
        <a class="portfolio__viewall" href={projects.viewAllHref} data-animate="fade">
          {projects.viewAll}
          <span aria-hidden="true">↗</span>
        </a>
      )}
    </div>
    {!isTeaser && projects.intro && (
      <p class="portfolio__intro" data-animate="fade">{projects.intro}</p>
    )}

    <ul class="portfolio__list">
      {items.map((p, i) => (
        <li class="portfolio__item" data-animate="fade">
          <span class="portfolio__index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div class="portfolio__main">
            {p.image && (p.url ? (
              <a class="portfolio__media" href={p.url} target="_blank" rel="noopener noreferrer" aria-label={`${p.linkLabel} — ${p.name}`}>
                <img src={p.image} alt={`${p.name} — captura de pantalla`} width="1200" height="750" loading="lazy" decoding="async" />
              </a>
            ) : (
              <div class="portfolio__media">
                <img src={p.image} alt={`${p.name} — captura de pantalla`} width="1200" height="750" loading="lazy" decoding="async" />
              </div>
            ))}
            <div class="portfolio__head">
              <h3 class="portfolio__name">{p.name}</h3>
              <span class="portfolio__meta">
                <span class="portfolio__year">{p.year}</span>
                <span class="portfolio__sep" aria-hidden="true">·</span>
                <span class="portfolio__type">{p.type}</span>
              </span>
            </div>
            <p class="portfolio__desc">{p.desc}</p>
            <div class="portfolio__footer">
              <ul class="portfolio__tags">
                {p.tags.map((tag) => <li class="portfolio__tag">{tag}</li>)}
              </ul>
              {p.url && (
                <a
                  class="portfolio__link"
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${p.linkLabel} — ${p.name}`}
                >
                  {p.linkLabel}
                  <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          </div>
        </li>
      ))}
    </ul>

    {isTeaser && (
      <div class="portfolio__teaser-cta">
        <a class="btn btn--ghost" href={projects.viewAllHref}>{projects.viewAll}</a>
      </div>
    )}

    {!isTeaser && projects.cta && (
      <div class="portfolio__cta" data-animate="fade">
        <p class="portfolio__cta-text">{projects.cta.text}</p>
        <a class="btn btn--primary" href={wa(projects.cta.waMessage)} target="_blank" rel="noopener noreferrer">
          {projects.cta.label}
        </a>
      </div>
    )}
  </div>
</section>
