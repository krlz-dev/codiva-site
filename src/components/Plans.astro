---
const { t } = Astro.props;
const { plans, contact } = t;
const wa = (msg) => `https://wa.me/${contact.whatsapp.number}?text=${encodeURIComponent(msg)}`;
---

<section class="plans" id="plans" aria-labelledby="plans-heading">
  <div class="container">
    <div class="section-label">{plans.label}</div>
    <h2 class="plans__heading" id="plans-heading" data-animate="reveal">{plans.heading}</h2>
    <p class="plans__intro" data-animate="fade">{plans.intro}</p>

    <div class="plans__grid">
      {plans.models.map((m) => (
        <article class={`model${m.featured ? ' model--featured' : ''}`} data-animate="fade">
          {m.badge && <span class="model__badge">{m.badge}</span>}
          <div class="model__top">
            <span class="model__step">{m.step}</span>
            <span class="model__phase">{m.phase}</span>
          </div>
          <h3 class="model__name">{m.name}</h3>
          <span class="model__meta">{m.meta}</span>
          <p class="model__tagline">{m.tagline}</p>
          <ul class="model__features">
            {m.features.map((f) => <li>{f}</li>)}
          </ul>
          <a
            class={`btn ${m.featured ? 'btn--primary' : 'btn--ghost'} model__cta`}
            href={wa(m.waMessage)}
            target="_blank"
            rel="noopener noreferrer"
          >{m.cta}</a>
        </article>
      ))}
    </div>

    <p class="plans__note" data-animate="fade">{plans.note}</p>
  </div>
</section>
