---
const { t } = Astro.props;
const { footer } = t;
// Current year, evaluated at build time (updates on each deploy).
const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__inner">
      <div class="footer__brand">
        <span class="footer__logo">codiva<span class="reg">®</span></span>
        <span class="footer__copy">© {year} codiva. {footer.copy}</span>
      </div>
      <div class="footer__meta">
        <a href={footer.legal.href} class="footer__legal">{footer.legal.label}</a>
      </div>
    </div>
  </div>
</footer>
