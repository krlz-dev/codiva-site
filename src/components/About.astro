---
const { t } = Astro.props;
const { about } = t;
const tm = about.trademark;
---

<section class="about" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="section-label">{about.label}</div>
    <div class="about__grid">
      <div class="about__left">
        <h2 class="about__heading" id="about-heading" data-animate="reveal" set:html={about.headingHtml}></h2>
      </div>
      <div class="about__right">
        {about.paragraphs.map((p) => (
          <p class="about__text" data-animate="fade">{p}</p>
        ))}
        <aside class="trademark-note" id="trademark" aria-label={tm.label} data-animate="fade">
          <div class="trademark-note__head">
            <span class="trademark-note__badge" aria-hidden="true">®</span>
            <span class="trademark-note__label">{tm.label}</span>
          </div>
          <p class="trademark-note__text" set:html={tm.note}></p>
          <dl class="trademark-note__list">
            {tm.rows.map((row) => (
              <div class="trademark-note__row">
                <dt class="trademark-note__key">{row.key}</dt>
                <dd class="trademark-note__val" set:html={row.valHtml}></dd>
              </div>
            ))}
          </dl>
        </aside>
      </div>
    </div>
  </div>
</section>
