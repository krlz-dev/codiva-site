---
const { t } = Astro.props;
const { about } = t;
---

<section class="about" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="section-label">{about.label}</div>
    <div class="about__grid">
      <div class="about__left">
        <h2 class="about__heading" id="about-heading" data-animate="reveal" set:html={about.headingHtml}></h2>
      </div>
      <div class="about__right">
        {about.paragraphs.map((p) => (
          <p class="about__text" data-animate="fade">{p}</p>
        ))}
      </div>
    </div>
  </div>
</section>
