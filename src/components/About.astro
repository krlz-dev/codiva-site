---
const { t } = Astro.props;
const { about } = t;
---

<section class="about" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="section-label">{about.label}</div>
    <div class="about__grid">
      <div class="about__left">
        <h2 class="about__heading" id="about-heading" data-animate="reveal" set:html={about.headingHtml}></h2>
      </div>
      <div class="about__right">
        {about.paragraphs.map((p) => (
          <p class="about__text" data-animate="fade">{p}</p>
        ))}
      </div>
    </div>
    {about.capabilities && (
      <div class="about__capabilities" id="capabilities" data-animate="fade" aria-label={about.capabilitiesLabel}>
        <span class="about__capabilities-label">{about.capabilitiesLabel}</span>
        <ul class="about__capabilities-list">
          {about.capabilities.map((c) => <li>{c}</li>)}
        </ul>
      </div>
    )}
  </div>
</section>
