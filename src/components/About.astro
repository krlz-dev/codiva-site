---
import type { Content } from '../i18n/content';

interface Props {
  about: Content['about'];
}

const { about } = Astro.props;
---

<section class="about" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="section-label">{about.label}</div>
    <div class="about__grid">
      <div class="about__left">
        <h2 class="about__heading" id="about-heading" data-animate="reveal" set:html={about.heading}></h2>
      </div>
      <div class="about__right">
        {about.texts.map((text) => (
          <p class="about__text" data-animate="fade">{text}</p>
        ))}
        <div class="about__stats" data-animate="fade">
          {about.stats.map((stat) => (
            <div class="stat">
              <span class="stat__number">{stat.number}</span>
              <span class="stat__label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
