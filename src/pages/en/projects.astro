---
import Layout from '../../layouts/Layout.astro';
import Portfolio from '../../components/Portfolio.astro';
import Footer from '../../components/Footer.astro';
import en from '../../i18n/en.js';

const pr = en.projects;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: pr.meta.ogTitle,
    description: pr.meta.description,
    url: pr.meta.canonical,
    inLanguage: 'en',
    isPartOf: { '@type': 'WebSite', name: 'codiva®', url: 'https://codiva.cl' },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: pr.items.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'CreativeWork',
          name: p.name,
          description: p.desc,
          ...(p.url ? { url: p.url } : {}),
          image: `https://codiva.cl${p.image}`,
          creator: { '@type': 'Organization', name: 'codiva', url: 'https://codiva.cl' },
        },
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://codiva.cl/en/' },
      { '@type': 'ListItem', position: 2, name: 'Projects', item: pr.meta.canonical },
    ],
  },
];

const t = { ...en, meta: pr.meta, schema };
---

<Layout t={t} altEs="https://codiva.cl/proyectos/" altEn="https://codiva.cl/en/projects/">
  <header class="subpage-nav">
    <div class="container subpage-nav__inner">
      <a href="/en/" class="subpage-nav__logo" aria-label={en.nav.logoAria}>codiva<span class="reg">®</span></a>
      <a href="/en/" class="subpage-nav__back">{pr.back}</a>
    </div>
  </header>
  <main class="projects-page">
    <Portfolio t={en} variant="full" />
  </main>
  <Footer t={en} />
</Layout>
