---
import Layout from '../layouts/Layout.astro';
import Portfolio from '../components/Portfolio.astro';
import Footer from '../components/Footer.astro';
import es from '../i18n/es.js';

const pr = es.projects;

// Page-specific SEO meta + structured data (overrides the homepage shell).
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: pr.meta.ogTitle,
    description: pr.meta.description,
    url: pr.meta.canonical,
    inLanguage: 'es-CL',
    isPartOf: { '@type': 'WebSite', name: 'codiva®', url: 'https://codiva.cl' },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: pr.items.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'CreativeWork',
          name: p.name,
          description: p.desc,
          ...(p.url ? { url: p.url } : {}),
          image: `https://codiva.cl${p.image}`,
          creator: { '@type': 'Organization', name: 'codiva', url: 'https://codiva.cl' },
        },
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://codiva.cl/' },
      { '@type': 'ListItem', position: 2, name: 'Proyectos', item: pr.meta.canonical },
    ],
  },
];

// Reuse the locale shell but override SEO meta + hreflang for this page.
const t = { ...es, meta: pr.meta, schema };
---

<Layout t={t} altEs="https://codiva.cl/proyectos/" altEn="https://codiva.cl/en/projects/">
  <header class="subpage-nav">
    <div class="container subpage-nav__inner">
      <a href="/" class="subpage-nav__logo" aria-label={es.nav.logoAria}>codiva<span class="reg">®</span></a>
      <a href="/" class="subpage-nav__back">{pr.back}</a>
    </div>
  </header>
  <main class="projects-page">
    <Portfolio t={es} variant="full" />
  </main>
  <Footer t={es} />
</Layout>
